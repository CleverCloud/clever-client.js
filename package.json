{
  "name": "@clevercloud/client",
  "version": "12.6.0",
  "description": "JavaScript REST client and utils for Clever Cloud's API",
  "homepage": "https://github.com/CleverCloud/clever-client.js",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/CleverCloud/clever-client.js"
  },
  "keywords": [
    "clever-cloud",
    "api",
    "rest",
    "client"
  ],
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=22"
  },
  "exports": {
    "./cc-api-client.js": {
      "types": "./dist/src/clients/cc-api/cc-api-client.d.ts",
      "default": "./dist/src/clients/cc-api/cc-api-client.js"
    },
    "./cc-api-commands/*": {
      "types": "./dist/src/clients/cc-api/commands/*",
      "default": "./dist/src/clients/cc-api/commands/*"
    },
    "./cc-api-local-storage-store.js": {
      "types": "./dist/src/clients/cc-api/lib/store/local-storage-store.d.ts",
      "browser": "./dist/src/clients/cc-api/lib/store/local-storage-store.js"
    },
    "./cc-api-file-store.js": {
      "types": "./dist/src/clients/cc-api/lib/store/file-store.d.ts",
      "node": "./dist/src/clients/cc-api/lib/store/file-store.js"
    },
    "./cc-api-bridge-client.js": {
      "types": "./dist/src/clients/cc-api-bridge/cc-api-bridge-client.d.ts",
      "default": "./dist/src/clients/cc-api-bridge/cc-api-bridge-client.js"
    },
    "./cc-api-bridge-commands/*": {
      "types": "./dist/src/clients/cc-api-bridge/commands/*",
      "default": "./dist/src/clients/cc-api-bridge/commands/*"
    },
    "./redis-http-client.js": {
      "types": "./dist/src/clients/redis-http/redis-http-client.d.ts",
      "default": "./dist/src/clients/redis-http/redis-http-client.js"
    },
    "./redis-http-commands/*": {
      "types": "./dist/src/clients/redis-http/commands/*",
      "default": "./dist/src/clients/redis-http/commands/*"
    },
    "./utils/*": {
      "types": "./dist/src/utils/*",
      "default": "./dist/src/utils/*"
    },
    "./esm/*": {
      "types": "./dist/esm/*",
      "default": "./dist/esm/*"
    }
  },
  "scripts": {
    "api-usage-analyze": "node tasks/api-usage-analyze.js -i ../console3 -i ../clever-components -i ../clever-tools",
    "build": "node tasks/clean-dist.js && tsc -p tsconfig.build.json && node tasks/copy-type-sidecars.js",
    "endpoints-analyze": "node tasks/endpoints-analyze.js",
    "endpoints-generate": "node tasks/endpoints-generate.js",
    "endpoints-list": "node tasks/endpoints-list.js",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prepack:dev": "pnpm run build",
    "prepack:prod": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "prepack": "[ \"$DEV\" == \"true\" ] && pnpm run prepack:dev || pnpm run prepack:prod",
    "test": "pnpm run test:unit",
    "test:e2e": "vitest run --project node-e2e --project browser-e2e",
    "test:e2e:browser": "vitest run --project browser-e2e",
    "test:e2e:node": "vitest run --project node-e2e",
    "test:unit": "vitest run --project node-unit --project browser-unit",
    "test:unit:browser": "vitest run --project browser-unit",
    "test:unit:browser:watch": "vitest --project browser-unit",
    "test:unit:node": "vitest run --project node-unit",
    "test:unit:node:watch": "vitest --project node-unit",
    "test:unit:watch": "vitest --project node-unit --project browser-unit",
    "typecheck": "tsc -p tsconfig.ci.json"
  },
  "dependencies": {
    "component-emitter": "^1.3.0",
    "fetch-event-stream": "^0.1.6"
  },
  "peerDependencies": {
    "eventsource": "^4.0.0"
  },
  "devDependencies": {
    "@babel/parser": "^7.28.5",
    "@babel/traverse": "^7.28.5",
    "@babel/types": "^7.28.5",
    "@clevercloud/doublure": "^0.0.5",
    "@clevercloud/eslint-config": "^1.1.0",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/compat": "^1.4.1",
    "@eslint/js": "^9.39.4",
    "@inquirer/prompts": "^7.10.1",
    "@scalar/openapi-parser": "^0.23.2",
    "@scalar/openapi-types": "^0.5.1",
    "@scalar/types": "^0.4.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/component-emitter": "^1.2.14",
    "@types/eventsource": "^1.1.15",
    "@types/fs-extra": "^11.0.4",
    "@vitest/browser": "^4.1.8",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/expect": "^4.1.8",
    "babel-plugin-dynamic-import-node": "^2.3.3",
    "change-case": "^5.4.4",
    "cheerio": "^1.1.2",
    "cookie": "^1.0.2",
    "eslint": "^9.39.3",
    "eslint-plugin-import-x": "^4.16.1",
    "fs-extra": "^11.3.2",
    "globals": "^16.5.0",
    "http-proxy-3": "^1.23.3",
    "playwright": "^1.60.0",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "safe-stringify": "^1.2.0",
    "tinyglobby": "^0.2.15",
    "totp-generator": "^2.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
